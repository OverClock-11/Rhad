Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "Initialization", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"api", " ", "=", " ", 
     FractionBox["\[Alpha]s", "\[Pi]"]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"mu", " ", "=", " ", 
     RowBox[{"Sqrt", "[", "scms", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dlsmu", " ", "=", " ", 
     RowBox[{"Log", "[", 
      FractionBox["scms", 
       SuperscriptBox["mu", "2"]], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lcharm", " ", "=", " ", "False"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lbottom", "=", " ", "False"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ltop", " ", "=", " ", "False"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Lcharm", "[", "x0_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", " ", "=", "x0"}], " ", "}"}], ",", 
       RowBox[{
        RowBox[{"qrkNum", " ", "=", " ", "4"}], ";", " ", 
        RowBox[{"lcharm", " ", "=", " ", "True"}], ";"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Lbottom", "[", "x0_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", " ", "=", "x0"}], " ", "}"}], ",", 
       RowBox[{
        RowBox[{"qrkNum", " ", "=", " ", "5"}], ";", " ", 
        RowBox[{"lbottom", " ", "=", " ", "True"}], ";", " ", 
        RowBox[{"lcharm", " ", "=", " ", "True"}], ";"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Ltop", "[", "x0_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", " ", "=", "x0"}], " ", "}"}], ",", 
       RowBox[{
        RowBox[{"qrkNum", " ", "=", " ", "6"}], ";", " ", 
        RowBox[{"ltop", " ", "=", " ", "True"}], ";", " ", 
        RowBox[{"lbottom", " ", "=", " ", "True"}], ";", " ", 
        RowBox[{"lcharm", " ", "=", " ", "True"}], ";"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Sqrt", "[", "scms", "]"}], "<", " ", "4.8"}], ",", " ", 
      RowBox[{"qrkNum", " ", "=", " ", "3"}], ",", " ", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Sqrt", "[", "scms", "]"}], "<", " ", "11.2"}], ",", 
        RowBox[{"Lcharm", "[", "1", "]"}], ",", " ", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Sqrt", "[", "scms", "]"}], "<", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", "*", 
              RowBox[{"qrkMass", "[", 
               RowBox[{"[", "6", "]"}], "]"}]}], " ", "+", " ", "10"}], 
            ")"}]}], ",", " ", 
          RowBox[{"Lbottom", "[", "1", "]"}], ",", " ", 
          RowBox[{"Ltop", "[", "1", "]"}]}], "]"}]}], "\[IndentingNewLine]", 
       "]"}]}], "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"inffin", " ", "=", " ", "3"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{"ltop", ",", " ", 
      RowBox[{"inffin", " ", "=", " ", "6"}], ",", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{"lbottom", ",", " ", 
        RowBox[{"inffin", " ", "=", " ", "5"}], ",", " ", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{"lcharm", ",", " ", 
          RowBox[{"inffin", " ", "=", " ", "4"}]}], "]"}]}], 
       "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Rhad", "[", 
      RowBox[{
      "scms0_", ",", " ", "qrkNum0_", ",", " ", "order0_", ",", " ", 
       "api0_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"scms", " ", "=", " ", "scms0"}], ",", " ", 
         RowBox[{"qrkNum", " ", "=", " ", "qrkNum0"}], ",", " ", 
         RowBox[{"order", " ", "=", " ", "order0"}], ",", " ", 
         RowBox[{"api", " ", "=", " ", "api0"}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Rsum", " ", "=", " ", "0"}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Non", "-", "singlet"}], "*)"}], "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"Rsum", " ", "=", " ", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{"Rqrk", "[", 
            RowBox[{
            "scms", ",", " ", "i", ",", " ", "order", ",", " ", "api"}], 
            "]"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"i", ",", " ", "qrkNum"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", "singlet", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"Rsum", " ", "=", " ", 
         RowBox[{"Rsum", " ", "+", " ", 
          RowBox[{"rsinglet", "[", "scms", "]"}]}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", "QED", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"Rsum", " ", "=", " ", 
         RowBox[{"Rsum", " ", "+", " ", 
          RowBox[{"\[Delta]RQED", "[", 
           RowBox[{"order", ",", " ", "api", ",", " ", "qrkNum"}], "]"}]}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"Return", "[", "Rsum", "]"}], ";"}]}], "\[IndentingNewLine]", 
      "]"}]}], ";"}]}]}]], "Input",
